#include <stdio.h>
#include <string.h>
#include <time.h>

int main() {
    char str[100];
    int state = 0;
    clock_t start, end;
    double time_taken;

    printf("Enter a string: ");
    scanf("%s", str);

    start = clock();

    // DFA Simulation
    for (int i = 0; str[i] != '\0'; i++) {
        switch (state) {
            case 0:
                if (str[i] == 'a')
                    state = 0;
                else if (str[i] == 'b')
                    state = 1;
                else {
                    printf("Invalid Input\n");
                    return 0;
                }
                break;

            case 1:
                if (str[i] == 'a')
                    state = 0;
                else if (str[i] == 'b')
                    state = 1;
                else {
                    printf("Invalid Input\n");
                    return 0;
                }
                break;
        }
    }

    end = clock();

    time_taken = ((double)(end - start)) / CLOCKS_PER_SEC;

    if (state == 1)
        printf("String Accepted\n");
    else
        printf("String Rejected\n");

    printf("Execution Time: %.6f seconds\n", time_taken);

    return 0;
}
